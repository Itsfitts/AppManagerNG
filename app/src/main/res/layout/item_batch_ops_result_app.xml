<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.AppTheme.V2.Card.ListRow"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="?attr/listItemMarginHorizontal"
    android:layout_marginVertical="@dimen/main_list_card_margin_vertical"
    app:contentPadding="@dimen/premium_space_12">

    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:minHeight="@dimen/premium_scanner_card_min_height"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/premium_space_4"
        android:paddingVertical="@dimen/premium_space_4">

        <com.google.android.material.imageview.ShapeableImageView
            android:layout_width="@dimen/premium_icon_48"
            android:layout_height="@dimen/premium_icon_48"
            android:background="?attr/colorErrorContainer"
            android:contentDescription="@null"
            android:importantForAccessibility="no"
            android:padding="@dimen/premium_space_8"
            android:src="@drawable/ic_information_circle"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.AppTheme.CircleComponent"
            app:tint="?attr/colorOnErrorContainer" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@android:id/text1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/premium_space_12"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="2"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textColor="?attr/colorOnSurface"
            tools:text="@string/app_name" />

    </androidx.appcompat.widget.LinearLayoutCompat>

</com.google.android.material.card.MaterialCardView>
