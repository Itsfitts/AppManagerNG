<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="?attr/colorSecondaryContainer" />
            <stroke
                android:width="@dimen/premium_stroke_hairline"
                android:color="?attr/colorSecondary" />
            <corners android:radius="@dimen/premium_radius_card" />
        </shape>
    </item>
    <item android:state_focused="true">
        <shape>
            <solid android:color="?attr/colorPrimaryContainer" />
            <stroke
                android:width="@dimen/premium_stroke_focus"
                android:color="?attr/colorPrimary" />
            <corners android:radius="@dimen/premium_radius_card" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="?attr/colorSecondaryContainer" />
            <stroke
                android:width="@dimen/premium_stroke_hairline"
                android:color="?attr/colorOutlineVariant" />
            <corners android:radius="@dimen/premium_radius_card" />
        </shape>
    </item>
</selector>
